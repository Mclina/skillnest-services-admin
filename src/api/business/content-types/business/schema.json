{
  "kind": "collectionType",
  "collectionName": "businesses",
  "info": {
    "singularName": "business",
    "pluralName": "businesses",
    "displayName": "Business ",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string",
      "required": true
    },
    "Address": {
      "type": "string",
      "required": true
    },
    "Clients": {
      "type": "string",
      "required": true
    },
    "Year_of_Experience": {
      "type": "string",
      "required": true
    },
    "StartTime": {
      "type": "time",
      "required": true
    },
    "EndTime": {
      "type": "time",
      "required": true,
      "default": "17:30:00.000"
    },
    "About": {
      "type": "richtext",
      "required": true
    },
    "categories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::category.category",
      "mappedBy": "category"
    },
    "Phone": {
      "type": "string",
      "required": true
    },
    "Image": {
      "type": "media",
      "multiple": true,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Premium": {
      "type": "boolean"
    },
    "booking": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::booking.booking",
      "inversedBy": "businesses"
    }
  }
}
